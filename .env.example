# ===========================================
# MarkyPie Environment Variables
# ===========================================
# For LOCAL dev: copy to .env and fill in values
# For RAILWAY: set these in the Railway dashboard (Variables tab)
# For VERCEL: set NEXT_PUBLIC_API_URL in the Vercel dashboard
# ===========================================

# ---- REQUIRED (Railway provides these automatically when you add DB/Redis services) ----

# PostgreSQL connection string
# Railway: auto-set when you add a PostgreSQL service
# Local: postgresql://postgres:markypie@localhost:5432/markypie
DATABASE_URL=postgresql://postgres:markypie@localhost:5432/markypie

# Redis connection string
# Railway: auto-set when you add a Redis service
# Local (Memurai on Windows): redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ---- OPTIONAL (all have working defaults) ----

# Node environment — set to "production" on Railway
NODE_ENV=development

# Server port (Railway sets this automatically — do not change on Railway)
PORT=3001

# Polygon RPC for on-chain indexing
# Public RPC (rate-limited): https://polygon-bor-rpc.publicnode.com
# Get a free dedicated key: https://www.alchemy.com/ or https://infura.io/
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# Polymarket APIs (no auth needed for read-only access)
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_DATA_API=https://data-api.polymarket.com
POLYMARKET_CLOB_API=https://clob.polymarket.com
POLYMARKET_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Kalshi API (no auth needed for market data)
KALSHI_API=https://api.elections.kalshi.com/trade-api/v2

# Whale detection threshold in USD (default: $10,000)
WHALE_THRESHOLD=10000

# ---- FRONTEND (set in Vercel dashboard) ----
# NEXT_PUBLIC_API_URL=https://your-app.railway.app
